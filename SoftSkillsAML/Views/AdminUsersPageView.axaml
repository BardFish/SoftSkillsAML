<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="650"
             x:Class="SoftSkillsAML.AdminUsersPageView"
             xmlns:vm="using:SoftSkillsAML.ViewModels"
             x:DataType="vm:AdminUsersPageViewModel">
  <Grid Margin="16" RowDefinitions="Auto,Auto,*">
    <TextBlock Text="Пользователи" FontSize="24" FontWeight="Bold" Margin="0,0,0,12"/>
    <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8" Margin="0,0,0,12">
      <TextBox Watermark="Мин. возраст" Text="{Binding MinAge}" Width="120"/>
      <TextBox Watermark="Мин. прогресс %" Text="{Binding MinProgress}" Width="140"/>
      <Button Content="Применить фильтр" Command="{Binding ApplyFilters}"/>
      <Button Content="Блок/разблок" Command="{Binding ToggleBlock}"/>
      <Button Content="Профиль игрока" Command="{Binding OpenProfile}"/>
      <Button Content="Назад" Command="{Binding BackToStat}"/>
    </StackPanel>
    <ListBox Grid.Row="2" ItemsSource="{Binding Users}" SelectedItem="{Binding SelectedUser}">
      <ListBox.ItemTemplate>
        <DataTemplate>
          <Border BorderBrush="#DDD" BorderThickness="1" Padding="8" Margin="0,0,0,8">
            <TextBlock>
              <Run Text="{Binding Login}"/>
              <Run Text=" | возраст: "/><Run Text="{Binding Age}"/>
              <Run Text=" | прогресс: "/><Run Text="{Binding Progress}"/><Run Text="%"/>
              <Run Text=" | блок: "/><Run Text="{Binding IsBlocked}"/>
            </TextBlock>
          </Border>
        </DataTemplate>
      </ListBox.ItemTemplate>
    </ListBox>
  </Grid>
</UserControl>
