<UserControl xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
			 x:Class="SoftSkillsAML.AuthPageView"
			 xmlns:vm="using:SoftSkillsAML.ViewModels"
			 x:DataType="vm:AuthPageViewModel"
			 xmlns:conv="using:SoftSkillsAML.Converters">
	<UserControl.Resources>
		<conv:AssetsImageConverter x:Key="AIC"/>
	</UserControl.Resources>
	<StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="20">
		<TextBlock Text="Авторизация" HorizontalAlignment="Center"/>
		<TextBox Text="{Binding Login}" Watermark="Логин"/>
		<StackPanel Orientation="Horizontal" HorizontalAlignment="Stretch">
			<TextBox Text="{Binding Password}" Watermark="Пароль" PasswordChar="*" RevealPassword="{Binding IsPasswordVisible}" HorizontalAlignment="Stretch"/>
			<Button Command="{Binding ChangePasswordVisibility}">
				<Image Source="{Binding Eye, Converter={StaticResource AIC}}" Height="20"/>
			</Button>
		</StackPanel>
		<Button Content="Войти" HorizontalAlignment="Center" Command="{Binding Auth}"/>
		<TextBlock Text="Нет аккаунта?">
			<InlineUIContainer>
				<HyperlinkButton Content="Зарегистрироваться" Command="{Binding ToReg}"/>
			</InlineUIContainer>
		</TextBlock>
	</StackPanel>
</UserControl>
