<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="500"
             x:Class="SoftSkillsAML.AddAchievementPageView"
             xmlns:vm="using:SoftSkillsAML.ViewModels"
             x:DataType="vm:AddAchievementPageViewModel">
  <Grid Margin="16" RowDefinitions="Auto,Auto,Auto,Auto,Auto">
    <TextBlock Text="Добавление достижения" FontSize="24" FontWeight="Bold" Margin="0,0,0,12"/>
    <TextBox Grid.Row="1" Text="{Binding Name}" Watermark="Название" Margin="0,0,0,8"/>
    <TextBox Grid.Row="2" Text="{Binding Description}" Watermark="Описание" Height="120" AcceptsReturn="True" Margin="0,0,0,8"/>

    <StackPanel Grid.Row="3" Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
      <Button Content="Выбрать изображение" Click="SelectImageClick"/>
      <TextBlock VerticalAlignment="Center" Text="{Binding ImageFileName}"/>
    </StackPanel>

    <StackPanel Grid.Row="4" Orientation="Horizontal" Spacing="8">
      <Button Content="Добавить" Command="{Binding AddAchievement}"/>
      <Button Content="Назад" Command="{Binding BackToStat}"/>
    </StackPanel>
  </Grid>
</UserControl>
