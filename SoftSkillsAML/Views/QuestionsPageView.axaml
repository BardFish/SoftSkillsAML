<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="600"
             x:Class="SoftSkillsAML.QuestionsPageView"
             xmlns:vm="using:SoftSkillsAML.ViewModels"
             x:DataType="vm:QuestionsPageViewModel">
  <Grid Margin="16" RowDefinitions="Auto,Auto,Auto,*">
    <TextBlock Text="{Binding DepartmentName}" FontSize="24" FontWeight="Bold" Margin="0,0,0,12"/>
    <TextBlock Grid.Row="1" Text="{Binding DepartmentDescription}" TextWrapping="Wrap" Margin="0,0,0,12"/>
    <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8" Margin="0,0,0,12">
      <Button Content="Открыть задание" Command="{Binding OpenQuestion}"/>
      <Button Content="Назад к направлениям" Command="{Binding BackToDepartments}"/>
    </StackPanel>

    <ListBox Grid.Row="3" ItemsSource="{Binding Questions}" SelectedItem="{Binding SelectedQuestion}">
      <ListBox.ItemsPanel><ItemsPanelTemplate><WrapPanel Orientation="Horizontal" ItemWidth="420"/></ItemsPanelTemplate></ListBox.ItemsPanel>
      <ListBox.ItemTemplate>
        <DataTemplate>
          <Border BorderBrush="#DDD" BorderThickness="1" Padding="8" Margin="6">
            <StackPanel Width="390">
              <TextBlock Text="{Binding Number}" TextWrapping="Wrap"/>
              <TextBlock Text="{Binding IsAnswered, StringFormat=Пройдено: {0}}"/>
            </StackPanel>
          </Border>
        </DataTemplate>
      </ListBox.ItemTemplate>
    </ListBox>
  </Grid>
</UserControl>
