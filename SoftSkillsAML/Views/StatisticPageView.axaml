<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="650"
             x:Class="SoftSkillsAML.StatisticPageView"
             xmlns:vm="using:SoftSkillsAML.ViewModels"
             x:DataType="vm:StatisticPageViewModel">
  <ScrollViewer>
    <Grid Margin="16" RowDefinitions="Auto,Auto,Auto,*">
      <TextBlock Text="Статистика администратора" FontSize="24" FontWeight="Bold" Margin="0,0,0,12"/>
      <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8" Margin="0,0,0,12">
        <Button Content="Пользователи" Command="{Binding OpenUsers}"/>
        <Button Content="Добавить задание" Command="{Binding OpenAddQuestion}"/>
        <Button Content="Добавить достижение" Command="{Binding OpenAddAchievement}"/>
        <Button Content="Выйти" Command="{Binding Logout}"/>
      </StackPanel>

      <GroupBox Grid.Row="2" Header="Конверсия по направлениям" Margin="0,0,0,12">
        <ItemsControl ItemsSource="{Binding DepartmentConversion}">
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <TextBlock>
                <Run Text="{Binding DepartmentName}"/>
                <Run Text=": начали "/>
                <Run Text="{Binding Started}"/>
                <Run Text=", завершили "/>
                <Run Text="{Binding Completed}"/>
              </TextBlock>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </GroupBox>

      <GroupBox Grid.Row="3" Header="Средние показатели навыков">
        <ItemsControl ItemsSource="{Binding SkillsAverages}">
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <TextBlock Text="{Binding SkillName, StringFormat={}{0}: }">
                <Run Text="{Binding Average, StringFormat={}{0:F2}}"/>
              </TextBlock>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </GroupBox>
    </Grid>
  </ScrollViewer>
</UserControl>
