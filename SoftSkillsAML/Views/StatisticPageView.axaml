<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:lvc="using:LiveChartsCore.SkiaSharpView.Avalonia"
             mc:Ignorable="d" d:DesignWidth="1100" d:DesignHeight="800"
             x:Class="SoftSkillsAML.StatisticPageView"
             xmlns:vm="using:SoftSkillsAML.ViewModels"
             x:DataType="vm:StatisticPageViewModel">
  <ScrollViewer>
    <Grid Margin="16" RowDefinitions="Auto,Auto,Auto,Auto,*">
      <TextBlock Text="Статистика администратора" FontSize="24" FontWeight="Bold" Margin="0,0,0,12"/>
      <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8" Margin="0,0,0,12">
        <Button Content="Пользователи" Command="{Binding OpenUsers}"/>
        <Button Content="Добавить задание" Command="{Binding OpenAddQuestion}"/>
        <Button Content="Добавить достижение" Command="{Binding OpenAddAchievement}"/>
        <Button Content="Выйти" Command="{Binding Logout}"/>
      </StackPanel>

      <Border Grid.Row="2" BorderBrush="#DDD" BorderThickness="1" Padding="10" Margin="0,0,0,12"><StackPanel><TextBlock Text="Конверсия по направлениям" FontSize="16" FontWeight="SemiBold"/>
        <ItemsControl ItemsSource="{Binding DepartmentConversion}"><ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate></ItemsControl.ItemsPanel><ItemsControl.ItemTemplate><DataTemplate><StackPanel Width="240" Margin="6"><TextBlock Text="{Binding Name}"/><lvc:PieChart Series="{Binding Series}" Height="170"/><TextBlock Text="{Binding Percent, StringFormat={}{0}%}" HorizontalAlignment="Center"/></StackPanel></DataTemplate></ItemsControl.ItemTemplate></ItemsControl>
      </StackPanel></Border>

      <Border Grid.Row="3" BorderBrush="#DDD" BorderThickness="1" Padding="10" Margin="0,0,0,12"><StackPanel><TextBlock Text="Средние показатели навыков" FontSize="16" FontWeight="SemiBold"/>
        <ItemsControl ItemsSource="{Binding SkillsAverages}"><ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate></ItemsControl.ItemsPanel><ItemsControl.ItemTemplate><DataTemplate><StackPanel Width="240" Margin="6"><TextBlock Text="{Binding Name}"/><lvc:PieChart Series="{Binding Series}" Height="170"/><TextBlock Text="{Binding Percent, StringFormat={}{0}%}" HorizontalAlignment="Center"/></StackPanel></DataTemplate></ItemsControl.ItemTemplate></ItemsControl>
      </StackPanel></Border>

      <Border Grid.Row="4" BorderBrush="#DDD" BorderThickness="1" Padding="10"><StackPanel><TextBlock Text="Распределение возрастов пользователей (0-100)" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8"/>
        <lvc:CartesianChart Series="{Binding AgeDistributionSeries}" XAxes="{Binding AgeDistributionXAxes}" Height="260"/>
      </StackPanel></Border>
    </Grid>
  </ScrollViewer>
</UserControl>
