<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="700"
             x:Class="SoftSkillsAML.AddQuestionPageView"
             xmlns:vm="using:SoftSkillsAML.ViewModels"
             x:DataType="vm:AddQuestionPageViewModel">
  <ScrollViewer>
    <Grid Margin="16" RowDefinitions="Auto,Auto,Auto,Auto,Auto,*">
      <TextBlock Text="Добавление задания" FontSize="24" FontWeight="Bold" Margin="0,0,0,12"/>
      <ComboBox Grid.Row="1" ItemsSource="{Binding Departments}" SelectedItem="{Binding SelectedDepartment}" PlaceholderText="Направление" Margin="0,0,0,8"><ComboBox.ItemTemplate><DataTemplate><TextBlock Text="{Binding Name}"/></DataTemplate></ComboBox.ItemTemplate></ComboBox>
      <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
      <TextBox Width="120" Text="{Binding QuestionNumber}" Watermark="Номер"/>
      <TextBox Width="820" Text="{Binding QuestionText}" AcceptsReturn="True" Height="100" Watermark="Текст задания"/>
      </StackPanel>
      <StackPanel Grid.Row="3" Orientation="Horizontal" Spacing="8" Margin="0,0,0,8"><Button Content="Изображение задания" Click="SelectQuestionImageClick"/><TextBlock VerticalAlignment="Center" Text="{Binding QuestionImageName}"/></StackPanel>
      <StackPanel Grid.Row="4" Orientation="Horizontal" Spacing="8" Margin="0,0,0,8"><Button Content="Добавить вариант ответа" Command="{Binding AddAnswer}"/><Button Content="Удалить выбранный" Command="{Binding RemoveSelectedAnswer}"/><Button Content="Изображение варианта" Click="SelectAnswerImageClick"/></StackPanel>
      <StackPanel Grid.Row="5" Spacing="8">
        <ListBox ItemsSource="{Binding Answers}" SelectedItem="{Binding SelectedAnswer}">
          <ListBox.ItemTemplate><DataTemplate><Border BorderBrush="#DDD" BorderThickness="1" Padding="8" Margin="0,0,0,8"><StackPanel Spacing="6"><TextBox Text="{Binding Text}" Watermark="Текст варианта ответа"/><CheckBox IsChecked="{Binding IsCorrect}" Content="Правильный ответ"/><TextBlock Text="{Binding ImageName, StringFormat=Изображение: {0}}"/><ItemsControl ItemsSource="{Binding SkillPoints}"><ItemsControl.ItemTemplate><DataTemplate><StackPanel Orientation="Horizontal" Spacing="8" Margin="0,2,0,2"><TextBlock Width="240" Text="{Binding SoftSkillName}" VerticalAlignment="Center"/><TextBox Width="120" Text="{Binding PointsInput}" Watermark="Очки"/></StackPanel></DataTemplate></ItemsControl.ItemTemplate></ItemsControl></StackPanel></Border></DataTemplate></ListBox.ItemTemplate>
        </ListBox>
        <StackPanel Orientation="Horizontal" Spacing="8"><Button Content="Сохранить задание" Command="{Binding AddQuestion}"/><Button Content="Назад" Command="{Binding BackToStat}"/></StackPanel>
      </StackPanel>
    </Grid>
  </ScrollViewer>
</UserControl>
