<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="500"
             x:Class="SoftSkillsAML.AddQuestionPageView"
             xmlns:vm="using:SoftSkillsAML.ViewModels"
             x:DataType="vm:AddQuestionPageViewModel">
  <Grid Margin="16" RowDefinitions="Auto,Auto,Auto,Auto">
    <TextBlock Text="Добавление задания" FontSize="24" FontWeight="Bold" Margin="0,0,0,12"/>
    <ComboBox Grid.Row="1" ItemsSource="{Binding Departments}" SelectedItem="{Binding SelectedDepartment}" PlaceholderText="Направление" Margin="0,0,0,8">
      <ComboBox.ItemTemplate>
        <DataTemplate><TextBlock Text="{Binding Name}"/></DataTemplate>
      </ComboBox.ItemTemplate>
    </ComboBox>
    <TextBox Grid.Row="2" Text="{Binding QuestionText}" AcceptsReturn="True" Height="120" Watermark="Текст задания" Margin="0,0,0,8"/>
    <StackPanel Grid.Row="3" Orientation="Horizontal" Spacing="8">
      <Button Content="Добавить" Command="{Binding AddQuestion}"/>
      <Button Content="Назад" Command="{Binding BackToStat}"/>
    </StackPanel>
  </Grid>
</UserControl>
