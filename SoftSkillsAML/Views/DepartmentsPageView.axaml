<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="600"
             x:Class="SoftSkillsAML.DepartmentsPageView"
             xmlns:vm="using:SoftSkillsAML.ViewModels"
             x:DataType="vm:DepartmentsPageViewModel">
  <Grid Margin="16" RowDefinitions="Auto,Auto,*" ColumnDefinitions="*,Auto">
    <TextBlock Grid.Row="0" Grid.ColumnSpan="2" FontSize="24" FontWeight="Bold" Text="Список направлений" Margin="0,0,0,12"/>
    <StackPanel Grid.Row="1" Grid.ColumnSpan="2" Orientation="Horizontal" Spacing="8" Margin="0,0,0,12">
      <Button Content="Открыть задания" Command="{Binding OpenDepartment}"/>
      <Button Content="Личный кабинет" Command="{Binding OpenProfile}"/>
      <Button Content="Выйти" Command="{Binding Logout}"/>
    </StackPanel>

    <ListBox Grid.Row="2" Grid.ColumnSpan="2" ItemsSource="{Binding Departments}" SelectedItem="{Binding SelectedDepartment}">
      <ListBox.ItemTemplate>
        <DataTemplate>
          <Border BorderBrush="#DDD" BorderThickness="1" Padding="8" Margin="0,0,0,8">
            <StackPanel>
              <TextBlock Text="{Binding Name}" FontWeight="Bold"/>
              <TextBlock Text="{Binding Description}" TextWrapping="Wrap"/>
            </StackPanel>
          </Border>
        </DataTemplate>
      </ListBox.ItemTemplate>
    </ListBox>
  </Grid>
</UserControl>
